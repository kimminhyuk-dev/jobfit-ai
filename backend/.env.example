# Application
APP_NAME=jobfit-ai
APP_ENV=development
APP_PORT=8000

# Database (Docker로 PostgreSQL 띄운 뒤 사용)
DATABASE_URL=postgresql+psycopg://jobfit_user:CHANGE_ME@localhost:5432/jobfit_db

# JWT
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# Access Token Cookie
ACCESS_TOKEN_COOKIE_NAME=access_token
ACCESS_TOKEN_COOKIE_SECURE=false
ACCESS_TOKEN_COOKIE_SAMESITE=lax

# Refresh Token Cookie
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax

# CORS (쉼표 구분 없이 JSON 배열 형식)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]

# Work24 OpenAPI (https://www.work24.go.kr)
WORK24_BASE_URL=https://www.work24.go.kr
WORK24_JOB_API_KEY=CHANGE_ME
WORK24_DEPARTMENT_API_KEY=CHANGE_ME
WORK24_DUTY_API_KEY=CHANGE_ME
WORK24_COMMON_CODE_API_KEY=CHANGE_ME
WORK24_OCCUPATION_API_KEY=CHANGE_ME

# ALIO / 공공기관 채용정보 API
ALIO_BASE_URL=https://opendata.alio.go.kr
ALIO_API_KEY=CHANGE_ME
ALIO_RECRUIT_LIST_URL=CHANGE_ME_OPTIONAL
ALIO_RECRUIT_DETAIL_URL=CHANGE_ME_OPTIONAL

# Resume Upload
RESUME_UPLOAD_DIR=data/resumes
RESUME_MAX_UPLOAD_MB=10

# Google Gemini API (이력서 LLM 파싱에 사용, Free Tier 사용 가능)
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=CHANGE_ME

# OpenAI API (면접 연습 질문/평가에 사용)
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-5-mini
OPENAI_MAX_OUTPUT_TOKENS=6000
OPENAI_REASONING_EFFORT=low

# SMTP / 메일 발송 (Spring JobFolio의 spring.mail.* 를 Python 스타일로 이식)
# 아래 값은 예시(플레이스홀더)입니다. 실제 값은 .env 에만 넣고 절대 커밋하지 마세요.
# Gmail 사용 시 SMTP_PASSWORD 는 일반 비밀번호가 아니라 "앱 비밀번호"입니다.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-google-app-password

SMTP_AUTH=true
SMTP_USE_TLS=true
SMTP_REQUIRE_TLS=true

# 타임아웃은 밀리초 단위 (Spring connectiontimeout/timeout/writetimeout 대응)
SMTP_CONNECTION_TIMEOUT_MS=5000
SMTP_TIMEOUT_MS=5000
SMTP_WRITE_TIMEOUT_MS=5000

SMTP_SSL_TRUST=smtp.gmail.com

# Google Maps Static API (면접 메일에 첨부할 지도 이미지 생성용)
# https://console.cloud.google.com 에서 발급. 아래 값은 예시(플레이스홀더)입니다.
# 서버에서만 사용하며 메일 본문/링크에 키를 노출하지 않습니다.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_STATIC_BASE_URL=https://maps.googleapis.com/maps/api/staticmap
