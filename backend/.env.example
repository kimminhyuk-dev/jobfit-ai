# Application
APP_NAME=jobfit-ai
APP_ENV=development
APP_PORT=8000

# Database (Docker로 PostgreSQL 띄운 뒤 사용)
DATABASE_URL=postgresql+psycopg://jobfit_user:CHANGE_ME@localhost:5432/jobfit_db

# JWT
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# Refresh Token Cookie
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax

# CORS (쉼표 구분 없이 JSON 배열 형식)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]

# Work24 OpenAPI (https://www.work24.go.kr)
WORK24_BASE_URL=https://www.work24.go.kr
WORK24_JOB_API_KEY=CHANGE_ME
WORK24_DEPARTMENT_API_KEY=CHANGE_ME
WORK24_DUTY_API_KEY=CHANGE_ME
WORK24_COMMON_CODE_API_KEY=CHANGE_ME
WORK24_OCCUPATION_API_KEY=CHANGE_ME

# ALIO / 공공기관 채용정보 API
ALIO_BASE_URL=https://opendata.alio.go.kr
ALIO_API_KEY=CHANGE_ME

# Google Gemini API (이력서 LLM 파싱에 사용, Free Tier 사용 가능)
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=CHANGE_ME
